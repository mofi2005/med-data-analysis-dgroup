      "category": "血常规",
      "disease_relevance_matrix": {
        "Infection": {
          "weight": 0.9,
          "is_core": true,
          "threshold_alert": "> 10.0 or < 3.5",
          "note": "白细胞升高或降低均提示感染或免疫异常，为感染性疾病最核心的筛查指标"
        },
        "Leukemia": {
          "weight": 0.95,
          "is_core": true,
          "threshold_alert": "> 30.0 or < 2.0",
          "note": "显著异常的白细胞计数是白血病诊断与治疗监测的关键指标"
        },
        "Sepsis": {
          "weight": 0.85,
          "is_core": true,
          "threshold_alert": "> 12.0 or < 4.0",
          "note": "脓毒症时白细胞急剧变化，是SOFA评分外的核心辅助判断指标"
        },
        "Inflammation": {
          "weight": 0.7,
          "is_core": false,
          "threshold_alert": "> 10.0",
          "note": "白细胞升高为全身炎性反应的典型标志"
        }
      }
    },
