      "disease_relevance_matrix": {
        "Hepatitis": {
          "weight": 1.0,
          "is_core": true,
          "threshold_alert": "> 40",
          "note": "ALT是急性与慢性肝炎最敏感的核心标志物，升高程度与肝细胞损伤程度正相关"
        },
        "Liver Cirrhosis": {
          "weight": 0.85,
          "is_core": true,
          "threshold_alert": "轻度升高或正常",
