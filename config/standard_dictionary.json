        },
        "Drug-Induced Liver Injury": {
          "weight": 0.75,
          "is_core": false,
          "threshold_alert": "> 3倍正常上限",
          "note": "ALT急剧升高是药物性肝损伤的典型标志，用于用药安全监测"
